<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.motsic.MotionCueView
        android:id="@+id/motionCue"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F2C4C"/>

    <com.example.motsic.HorizonView
        android:id="@+id/horizonView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <View
        android:id="@+id/focusDot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_focus_dot"
        android:visibility="gone"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/modeGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:padding="6dp"
        android:background="#80000000"
        app:singleLine="true"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/modeCues"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/mode_cues"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/modeLine"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mode_line"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/modeDot"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/focus_dot"/>
    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:id="@+id/hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="100dp"
        android:padding="10dp"
        android:background="#80000000"
        android:text="@string/cues_hint"
        android:textColor="#FFFFFF"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnPopOut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:text="@string/pop_out"/>
</FrameLayout>
